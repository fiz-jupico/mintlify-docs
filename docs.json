            "group": "Accept Payments",
            "pages": [
              "docs/payments/overview",
              "docs/payments/tokenization",
              "docs/payments/web-components",
              "docs/payments/card-transactions",
              "docs/payments/ach-echeck",
              "docs/payments/wallets"
            ]
