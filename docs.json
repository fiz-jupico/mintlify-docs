    "params": {
      "expanded": "closed"
    },
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "examples": {
      "defaults": "required",
      "languages": [
        "curl",
        "python",
        "javascript",
        "node"
      ],
      "prefill": true,
      "autogenerate": true
