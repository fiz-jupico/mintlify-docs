              "docs/operations/security",
              "docs/operations/enhanced-card-verification",
              "docs/operations/tax-withholding",
              "docs/operations/go-live-checklist",
              "docs/operations/glossary"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Overview",
            "pages": [
              "api-reference/overview",
              "api-reference/authentication",
              "api-reference/environments-testing-data",
              "api-reference/responses",
              "api-reference/status-codes",
              "api-reference/transaction-status-handling",
              "api-reference/error-handling",
              "api-reference/error-codes",
              "api-reference/timeout-handling",
              "api-reference/webhooks",
              "api-reference/go-live-checklist"
            ]
          },
          {
            "group": "API Reference",
            "openapi": "openapi.json"
          },
          {
            "group": "Resources",
            "pages": [
              "api-reference/query-capabilities"
            ]
          }
        ]
      }
    ]
